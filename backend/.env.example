# MedExam Backend Environment Configuration

# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/medexam

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT Secret (change in production!)
SECRET_KEY=your-secret-key-change-in-production

# ============================================
# AI Model Configuration (国产大模型)
# ============================================

# 方案一：SiliconFlow (免费额度)
# 注册地址: https://cloud.siliconflow.cn
# AI_API_KEY=your-siliconflow-api-key
# AI_BASE_URL=https://api.siliconflow.cn/v1
# AI_MODEL=Qwen/Qwen2.5-7B-Instruct

# 方案二：MiniMax
# 注册地址: https://www.minimaxi.com/
# AI_API_KEY=your-minimax-api-key
# AI_BASE_URL=https://api.minimax.chat/v1
# AI_MODEL=MiniMax-M2

# 方案三：智谱 GLM
# 申请地址: https://open.bigmodel.cn/
# AI_API_KEY=your-zhipu-api-key
# AI_BASE_URL=https://open.bigmodel.cn/api/paas/v4
# AI_MODEL=glm-4

# 方案四：通义 Qwen
# 申请地址: https://dashscope.console.aliyun.com/
# AI_API_KEY=your-dashscope-api-key
# AI_BASE_URL=https://dashscope.aliyuncs.com/api/v1
# AI_MODEL=qwen-turbo
